<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HealthApp</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">❤ HealthApp</a>

                <div>
                    <a class="nav-link d-inline text-white" href="/">Home</a>
                    <a class="nav-link d-inline text-white" href="/Appointments">Appointments</a>
                    <a class="nav-link d-inline text-white" href="#">Services</a>
                    <a class="nav-link d-inline text-white" href="#">Contact</a>
                </div>
            </div>
        </nav>
    </header>

    <main class="flex-fill">
        <div class="container mt-4">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-dark text-white text-center p-3 mt-auto">
        © 2026 HealthApp - ASP.NET Core Healthcare System with AI Chatbot
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script type="text/javascript">
    (function(d, t) {
    var v = d.createElement(t), s = d.getElementsByTagName(t)[0];
    v.onload = function() {
    window.voiceflow.chat.load({
    verify: { projectID: '69fc41df69801bc3a95029ed' },
    url: 'https://general-runtime.voiceflow.com',
    voice: {
    url: "https://runtime-api.voiceflow.com"
    }
    });
    }
    v.src = "https://cdn.voiceflow.com/widget-next/bundle.mjs"; v.type = "text/javascript"; s.parentNode.insertBefore(v, s);
    })(document, 'script');
</script>