@model IEnumerable<AppointmentBookingWithChatbot.Models.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary">Patient Appointments</h1>
            <p class="text-muted">
                Manage healthcare appointments with AI-powered support
            </p>
        </div>

        <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm">
            + New Appointment
        </a>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0">Appointment Management</h4>
        </div>

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">
                    <tr>
                        <th>Patient</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Doctor</th>
                        <th>Date</th>
                        <th>Message</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td class="fw-semibold">
                                @item.PatientName
                            </td>

                            <td>
                                @item.Email
                            </td>

                            <td>
                                @item.Phone
                            </td>

                            <td>
                                @item.DoctorName
                            </td>

                            <td>
                                @item.AppointmentDate.ToString("MMM dd, yyyy")
                            </td>

                            <td style="max-width:250px;">
                                @item.Message
                            </td>

                            <td class="text-center">

                                <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1">
                                    Edit
                                </a>

                                <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-dark rounded-pill px-3 me-1">
                                    Details
                                </a>

                                <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>