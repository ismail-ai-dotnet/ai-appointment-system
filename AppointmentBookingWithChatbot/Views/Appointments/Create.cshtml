@model AppointmentBookingWithChatbot.Models.Appointment

@{
    ViewData["Title"] = "Create Appointment";
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold text-primary">Book Appointment</h1>
            <p class="text-muted">Schedule your healthcare appointment online</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-primary btn-lg rounded-pill px-4">
            View Appointments
        </a>
    </div>

    <div class="card shadow-lg border-0 rounded-4 p-4">
        <div class="row">
            <div class="col-md-7">

                <form asp-action="Create">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="PatientName" class="form-label fw-semibold"></label>
                        <input asp-for="PatientName" class="form-control form-control-lg rounded-3" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control form-control-lg rounded-3" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-semibold"></label>
                        <input asp-for="Phone" class="form-control form-control-lg rounded-3" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="DoctorName" class="form-label fw-semibold"></label>
                        <input asp-for="DoctorName" class="form-control form-control-lg rounded-3" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="AppointmentDate" class="form-label fw-semibold"></label>
                        <input asp-for="AppointmentDate" class="form-control form-control-lg rounded-3" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Message" class="form-label fw-semibold"></label>
                        <textarea asp-for="Message" rows="4" class="form-control rounded-3"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5">
                        Book Appointment
                    </button>

                </form>

            </div>

            <div class="col-md-5 d-flex align-items-center">
                <div class="p-4">
                    <h3 class="fw-bold text-primary">
                        AI Powered Healthcare
                    </h3>

                    <p class="text-muted mt-3">
                        Patients can quickly book appointments and get instant support using the integrated AI chatbot.
                    </p>

                    <ul class="list-unstyled mt-4">
                        <li class="mb-2">✅ Smart Appointment Booking</li>
                        <li class="mb-2">✅ AI Patient Support</li>
                        <li class="mb-2">✅ Doctor Availability</li>
                        <li class="mb-2">✅ Fast & Modern UI</li>
                    </ul>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}